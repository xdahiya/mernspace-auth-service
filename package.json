{
    "name": "authservice",
    "version": "1.0.0",
    "description": "user managment service",
    "main": "index.js",
    "scripts": {
        "dev": "nodemon src/server.ts",
        "format:check": "npx prettier . --check",
        "format:fix": "npx prettier . --write",
        "lint": "npx eslint .",
        "lint:fix": "npx eslint . --fix",
        "prepare": "husky install"
    },
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "@types/express": "^4.17.18",
        "@types/node": "^20.8.2",
        "@typescript-eslint/eslint-plugin": "^6.7.4",
        "@typescript-eslint/parser": "^6.7.4",
        "eslint": "^8.50.0",
        "eslint-config-prettier": "^9.0.0",
        "husky": "^8.0.3",
        "lint-staged": "^14.0.1",
        "nodemon": "^3.0.1",
        "prettier": "3.0.3",
        "ts-node": "^10.9.1",
        "typescript": "^5.2.2"
    },
    "lint-staged": {
        "*.ts": [
            "npm run lint:fix",
            "npm run format:fix"
        ]
    },
    "dependencies": {
        "dotenv": "^16.3.1",
        "express": "^4.18.2"
    }
